{
  "$comment": "Root Directory must be 'frontend'. Vercel installs Python deps from api/requirements.txt automatically — do not run pip in installCommand.",
  "buildCommand": "cp -r ../backend backend && npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
